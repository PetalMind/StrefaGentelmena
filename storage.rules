rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Kopie zapasowe RTDB (FirebaseRealtimeDatabaseBackup) — ścieżka: backups/…
    // Aplikacja nie używa jeszcze Firebase Auth: przed produkcją ogranicz np. request.auth != null
    // lub podpisane URL / Cloud Function z kontem serwisowym.
    match /backups/{allPaths=**} {
      allow read, write: if true;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
